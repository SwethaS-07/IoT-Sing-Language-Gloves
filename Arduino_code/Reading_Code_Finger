void setup() {
  Serial.begin(9600);
}

void loop() {
  int thumb  = analogRead(A0);
  int indexF = analogRead(A1);
  int middle = analogRead(A2);
  int ring   = analogRead(A3);
  int little = analogRead(A4);

  Serial.print("Thumb: ");
  Serial.print(thumb);
  Serial.print("\tIndex: ");
  Serial.print(indexF);
  Serial.print("\tMiddle: ");
  Serial.print(middle);
  Serial.print("\tRing: ");
  Serial.print(ring);
  Serial.print("\tLittle: ");
  Serial.println(little);

  delay(200);
}
